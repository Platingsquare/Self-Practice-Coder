import random

def generate_math_problem():
    num1 = random.randint(1, 50)
    num2 = random.randint(1, 50)
    operators = ['+', '-', '*', '/']
    operator = random.choice(operators)
    
    # Avoid division by zero
    if operator == '/' and num2 == 0:
        num2 = 1
    
    problem = f"{num1} {operator} {num2}"
    answer = eval(problem)  # Use eval carefully; in real apps, consider safer methods
    
    return problem, answer

def main():
    print("Welcome to the Math Practice Program!")
    total_questions = 5
    correct_answers = 0
    
    for i in range(total_questions):
        problem, correct_answer = generate_math_problem()
        user_input = input(f"Question {i+1}: What is {problem}? ")
        
        try:
            if float(user_input) == correct_answer:
                print("Correct!")
                correct_answers += 1
            else:
                print(f"Incorrect. The correct answer was {correct_answer}.")
        except ValueError:
            print("Invalid input. Please enter a number.")
    
    print(f"\nYou got {correct_answers}/{total_questions} correct!")

if __name__ == "__main__":
    main()
